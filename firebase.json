{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.md",
      "**/*.js.map",
      "**/package*.json",
      "firebase-admin-key.json",
      "setup-firebase.js",
      "deploy-rules.js",
      "check-firebase-students.js",
      "**/*.sh"
    ]
  }
}
