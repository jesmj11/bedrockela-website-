rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all students collection access (open for testing)
    match /students/{student} {
      allow read, write: if true;
    }
    
    // Allow all families collection access (open for testing)
    match /families/{family} {
      allow read, write: if true;
    }
    
    // Allow lesson progress access (for student tracking)
    match /lessonProgress/{progress} {
      allow read, write: if true;
    }
    
    // Allow student answers access (for AI grading)
    match /studentAnswers/{answer} {
      allow read, write: if true;
    }
  }
}
